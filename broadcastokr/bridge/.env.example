# Bridge server configuration
BRIDGE_PORT=3001
BRIDGE_HOST=0.0.0.0
BRIDGE_API_KEY=change-me-to-a-random-secret
BRIDGE_LOG_DIR=./logs
BRIDGE_BACKUP_DIR=./backups
BRIDGE_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting (defense-in-depth). Max requests per IP per window.
# /api/health is always exempt. Defaults: 600 requests / 60000 ms.
BRIDGE_RATE_LIMIT=600
BRIDGE_RATE_WINDOW_MS=60000

# Optional: Oracle Instant Client path
# ORACLE_CLIENT_DIR=/opt/oracle/instantclient
